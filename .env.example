# Translator listen address
TRANSLATOR_HOST=127.0.0.1
TRANSLATOR_PORT=3002

# Upstream OpenAI-compatible chat-completions endpoint.
# If pointing at NewAPI during migration, use: http://127.0.0.1:3000/v1
# If replacing NewAPI, use the real upstream base URL, e.g. https://example.com/v1
UPSTREAM_BASE_URL=http://127.0.0.1:3000/v1
UPSTREAM_API_KEY=replace-me

# Comma-separated models exposed by /v1/models
TRANSLATOR_MODELS=claude-opus-4-7,gpt-5.5,qwen3.6-plus,gemini-2.5-flash
DEFAULT_MODEL=claude-opus-4-7

# Request timeout in milliseconds
UPSTREAM_TIMEOUT_MS=120000
